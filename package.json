{
    "name": "@beyonda-labs/angular-components",
    "version": "0.0.1",
    "publishConfig": {
        "registry": "https://npm.pkg.github.com/"
    },
    "scripts": {
        "build": "npm run test:ci && ng build",
        "build:quick": "npm run prebuild && ng build --configuration=development",
        "build:watch": "node scripts/build-watch.js",
        "check-translations": "node scripts/check-translations.js",
        "lint": "ng lint",
        "lint:fix": "ng lint --fix",
        "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
        "test:report": "jest --coverage --coverageReporters=lcov --coverageReporters=html",
        "merge-translations": "npm run check-translations && node scripts/merge-translations.js",
        "prebuild": "npm run merge-translations",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:ci": "jest --ci",
        "test:coverage": "jest --coverage",
        "update-translations": "npm run merge-translations && node scripts/update-translations.js"
    },
    "peerDependencies": {
        "@angular/animations": "19.2.17",
        "@angular/common": "19.2.17",
        "@angular/core": "19.2.17",
        "@angular/forms": "19.2.17",
        "@angular/platform-browser": "19.2.17",
        "@angular/platform-browser-dynamic": "19.2.17",
        "@angular/router": "19.2.17",
        "@ngx-translate/core": "16.0.4",
        "@ngx-translate/http-loader": "16.0.1",
        "bootstrap": "5.3.8",
        "monaco-editor": "0.52.2",
        "ngx-bootstrap": "19.0.2",
        "ngx-monaco-editor-v2": "19.0.2",
        "rxjs": "7.8.2",
        "zone.js": "0.15.1"
    },
    "dependencies": {
        "@fortawesome/angular-fontawesome": "1.0.0",
        "@fortawesome/fontawesome-svg-core": "6.7.1",
        "@fortawesome/free-brands-svg-icons": "6.7.1",
        "@fortawesome/free-regular-svg-icons": "6.7.1",
        "@fortawesome/free-solid-svg-icons": "6.7.1",
        "@interactjs/types": "1.10.27",
        "interactjs": "1.10.27",
        "ngx-toastr": "19.0.0",
        "tslib": "2.7.0",
        "uuid": "11.1.0"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "19.2.19",
        "@angular-eslint/builder": "19.8.1",
        "@angular-eslint/eslint-plugin": "19.8.1",
        "@angular-eslint/eslint-plugin-template": "19.8.1",
        "@angular-eslint/schematics": "19.8.1",
        "@angular-eslint/template-parser": "19.8.1",
        "@angular/cli": "19.2.19",
        "@angular/compiler-cli": "19.2.17",
        "@angular/localize": "19.2.17",
        "@stylistic/eslint-plugin-js": "^2.13.0",
        "@types/jest": "29.5.14",
        "@types/uuid": "10.0.0",
        "@typescript-eslint/eslint-plugin": "8.4.0",
        "@typescript-eslint/parser": "8.4.0",
        "eslint": "8.57.0",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "eslint-plugin-unicorn": "^56.0.1",
        "fs-extra": "11.3.3",
        "jest": "29.7.0",
        "jest-mock-extended": "^4.0.0",
        "jest-preset-angular": "14.6.2",
        "ng-packagr": "19.2.2",
        "prettier": "3.3.3",
        "sass": "1.97.1",
        "ts-node": "10.9.2",
        "typescript": "5.5.4"
    },
    "private": false,
    "sideEffects": true
}